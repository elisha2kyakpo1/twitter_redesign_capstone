<!DOCTYPE html>
<html>
  <head>
    <title>TwitterRedesignCapstone</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag 'application', media: 'all', 'data-turbolinks-track': 'reload' %>
    <%= javascript_pack_tag 'application', 'data-turbolinks-track': 'reload' %>
  </head>

  <body>
  	<header>
		<nav class = "navbar">
				
				<p><%#= link_to 'Posts', tweets_path %></p>
			<%#= form_tag search_posts_path, method: :get do %>
				<div class = 'search'>
					<p><%#= text_field_tag :search, nil, placeholder: 'Search...', class: 'search' %></p>
					<p><%#= submit_tag 'search', class: 'sub_search' %></p>
				</div>
			<%# end %>
			<% if current_user %>
				<h4>Welcome <%= current_user.username %></h4>
				<p class ="para_log_out"><%= link_to 'Log Out', logout_path, method: :delete %></p>
				<%# else %>
					<p class ="para_sign_in"><%#= link_to 'Sign In', new_session_path %></p>
					<p class ="para_sign_up"><%#= link_to 'Sign Up', new_user_path %></p>
			<% end %>
		</nav>
	</header>

    <%= yield %>
  </body>
</html>
