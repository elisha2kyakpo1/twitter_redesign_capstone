<!DOCTYPE html>
<html>
  <head>
    <title>Twitter_Redesign</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag 'application', media: 'all', 'data-turbolinks-track': 'reload' %>
    <%= javascript_pack_tag 'application', 'data-turbolinks-track': 'reload' %>
  </head>

  <body>
    <section class="sec2">
      <div class="logout">
        <div class="profile d-flex  mt-2">
          <div class="">
            <% if current_user %>
              <%#= image_tag(@user.photo_url) if @user.photo %>
              <h5 class="log"><%= link_to current_user.username, user_path(current_user), class: 'log' %></h5>
            <% end %>
          </div>
        </div>

        <div class="d-flex follow container-fluid">
          <% if current_user %>
          <div>
            <div class="stats1"><%= link_to current_user.following.count %></div>
            <p class="log_out mr-2">following</p>
          </div>
          <div>
            <div class="stats1"><%= link_to current_user.followers.count %></div>
            <div><p class="log_out">followers</p></div>
          </div>
          <% end %>
        </div>

        <div class="nav-side">
          <% if current_user %>
            <div class="log-homes"><h6 class="log"><%= link_to 'HOME', tweets_path, class: 'log' %></h6></div>
            <div class="log-homes"><h6 class="log"><%= link_to 'PROFILE', users_path, class: 'log' %></h6></div>
          <% end %>
        </div>
      </div>
    </section>

    <%= yield %>
  </body>
</html>
