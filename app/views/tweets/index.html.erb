<section class="main_sec">
  <header class="header">
    <% if current_user %>
      <h4><%= current_user.username %></h4>
      <p class ="para_log_out"><%= link_to 'Log Out', logout_path, method: :delete %></p>
    <% end %>
  </header>
  
      <%#= image_tag "image.jpg" %>
  <nav class = "navbar">
    <% if current_user %>
      <h4><%= link_to 'Tweets', tweets_path, class: 'links' %></h4>
      <h4><%= link_to 'Photos', class: 'links' %></h4>
      <h4><%= link_to 'Videos', class: 'links' %></h4>
    <% end %>
  </nav>

  <section class="sec1">
    <div>
      <div>
        <%= render 'form', tweet: @tweet %>
      </div>
    </div>

    <div class="tweet-show">
      <div>
        <p id="notice"><%= notice %></p>
        <% @tweets.each do |tweet| %>
          <div class="author-data">
            <h4 class="author"><%= link_to tweet.author.username %></h4>
            <p class="authored"><%= tweet.Text %></p>
            <small><%= time_ago_in_words(tweet.created_at) %> ago </small>
            <%#= link_to 'Show', tweet %>
            <%#= link_to 'Edit', edit_tweet_path(tweet) %>
            <%#= link_to 'Destroy', tweet, method: :delete, data: { confirm: 'Are you sure?' } %>
          </div>
        <% end %>
      </tbody>
    </div>
  </section>

  <section class="sec2">
    <div>
    </div>
  </section>

</section>