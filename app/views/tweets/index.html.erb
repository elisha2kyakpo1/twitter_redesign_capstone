<section class="d-grid row">  
      <%#= image_tag "image.jpg" %>
  <section class="sec2 container-fluid col-2">
    <div class="logout">
      <div class="profile d-flex mt-2">
        <div>
          <% if current_user %>
            <h5 class="user"><%= link_to current_user.username, class: 'user' %></h5>
            <p><%= link_to 'Log Out', logout_path, method: :delete, class: 'log_out' %></p>
          <% end %>
        </div>
      </div>

      <div class="d-flex follow container-fluid">
        <div>
           <%#= @users.follower.count %>
          <p class="log_out mr-2">following</p>
        </div>
           <%#= @users.followed.count %>
        <div><p class="log_out">followers</p></div>
      </div>

      <div class="nav-side">
        <% if current_user %>
          <div class="log-homes"><h6 class="log"><%= link_to 'HOME', tweets_path, class: 'log' %></h6></div>
          <div class="log-homes"><h6 class="log">CONNECT</h6></div>
          <div class="log-homes"><h6 class="log">DISCOVER</h6></div>
          <div class="log-homes"><h6 class="log"><%= link_to 'PROFILE', users_path, class: 'log' %></h6></div>
        <% end %>
      </div>
    </div>
  </section>

  <section class="sec1 p-0 col-10">
    <header class="header">
      <% if current_user %>
        <h4><%= current_user.username %></h4>
        <p class ="para_log_out"><%= link_to 'Log Out', logout_path, method: :delete %></p>
      <% end %>
    </header>

  <section class="container-inner d-flex">
    <section class="tweets-container">
      <nav class = "navbar1">
        <% if current_user %>
          <h4><%= link_to 'Tweets', tweets_path, class: 'links' %></h4>
        <% end %>
      </nav>
        <hr class="mt-0">
      <div>
        <div>
          <%= render 'form', tweet: @tweet %>
        </div>
      </div>

      <div class="tweet-show">
        <div>
          <div>
            <h5 class="new_tweets">8 new tweets<h5>
          </div>
          <hr>

          <div>
            <p id="notice"><%= notice %></p>
            <% @tweets.each do |tweet| %>
              <div class="author-data container-fluid ml-2">
                <h4 class="author"><%= link_to tweet.author.username %></h4>
                <p class="authored"><%= tweet.Text %></p>
                <small><%= time_ago_in_words(tweet.created_at) %> ago </small>
                <%#= link_to 'Show', tweet %>
                <%#= link_to 'Edit', edit_tweet_path(tweet) %>
                <%#= link_to 'Destroy', tweet, method: :delete, data: { confirm: 'Are you sure?' } %>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </section>

    <article class="articles p-0 col-4">
      <div>
        <h4 class="text-center pt-2">Who to follow</h4>
      </div>
        <hr class="mt-0">
      <div class="container-fluid ml-5">
        <% @users.each do |user| %>
          <% if user.followings %>
            <h5><%= user.username %></h5>
            <p class="secondary">Followed by <%= link_to '@jamesking', class: 'followed_by' %></p>
          <% end %>
        <% end %>
      </div>
    </article>
  </section>
</section>

