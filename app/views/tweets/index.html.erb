<section class="d-grid row">  
  <section class="sec2 col-2">
    <div class="logout">
      <div class="profile d-flex  mt-2">
        <div class="">
          <% if current_user %>
            <%= image_tag(@user.photo_url) if @user.photo %>
            <h5 class="log"><%= link_to current_user.username, user_path(current_user), class: 'log' %></h5>
          <% end %>
        </div>
      </div>

      <div class="d-flex follow container-fluid">
        <% if current_user %>
        <div>
          <div class="stats1"><%= link_to current_user.following.count %></div>
          <p class="log_out mr-2">following</p>
        </div>
        <div>
          <div class="stats1"><%= link_to current_user.followers.count %></div>
          <div><p class="log_out">followers</p></div>
        </div>
        <% end %>
      </div>

      <div class="nav-side">
        <% if current_user %>
          <div class="log-homes"><h6 class="log"><%= link_to 'HOME', tweets_path, class: 'log' %></h6></div>
          <div class="log-homes"><h6 class="log"><%= link_to 'PROFILE', users_path, class: 'log' %></h6></div>
        <% end %>
      </div>
    </div>
  </section>

  <section class="sec1 p-0 col-10">
    <header class="header">
      <% if current_user %>
        <%= link_to 'Log Out', logout_path, class: 'log_out_btn', method: :delete %>
      <% end %>
    </header>

    <section class="container-inner d-flex">
      <section class="tweets-container">
        <nav class = "navbar1">
          <% if current_user %>
            <p class="links"><%= link_to 'Tweets', tweets_path, class: 'links' %></p>
          <% end %>
        </nav>
          <hr class="mt-0">
        <div>
          <div>
            <%= render 'form', tweet: @tweet %>
          </div>
        </div>

        <div class="tweet-show">
          <div>
            <div>
              <h5 class="new_tweets">8 new tweets<h5>
            </div>
            <hr>

            <div>
              <p id="notice"><%= notice %></p>
              <% @tweets.each do |tweet| %>
                <div class="author-data container-fluid ml-2">
                  <h4 class="log_user"><%= link_to tweet.author.username.titleize, users_path, class: 'user_name' %></h4>
                  <small><%= time_ago_in_words(tweet.created_at) %> ago </small>
                  <p class="authored"><%= tweet.Text %></p>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      </section>

      <article class="articles p-0 col-4">
        <div>
          <h4 class="text-center pt-2">Who to follow</h4>
        </div>
          <hr class="mt-0">
        <div class="container-fluid ml-5">
          <% @users.each do |user| %>
            <% if user.following %>
              <h4 class="log_users"><%= link_to user.username.titleize, users_path, class: 'to_follow' %></h4>
              <p class="secondary">Followed by <%= link_to '@jamesking', class: 'followed_by' %></p>
            <% end %>
          <% end %>
        </div>
      </article>
    </section>
  </section>
</section>

