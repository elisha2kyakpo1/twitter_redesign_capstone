<section class="d-grid row">  
  <section class="sec2 col-2">
    <div class="logout">
      <div class="profile d-flex mt-2">
        <div>
          <% if current_user %>
            <%#= image_tag (@user.photo_url) %>
            <h5 class="log"><%= link_to current_user.username, users_path, class: 'log' %></h5>
          <% end %>
        </div>
      </div>

      <div class="d-flex follow container-fluid">
        <% if current_user %>
        <div>
          <div class="stats1"><%= link_to current_user.following.count %></div>
          <p class="log_out mr-2">following</p>
        </div>
        <div>
          <div class="stats1"><%= link_to current_user.followers.count %></div>
          <div><p class="log_out">followers</p></div>
        </div>
        <% end %>
      </div>

      <div class="nav-side">
        <% if current_user %>
          <div class="log-homes"><h6 class="log"><%= link_to 'HOME', tweets_path, class: 'log' %></h6></div>
          <div class="log-homes"><h6 class="log"><%= link_to 'PROFILE', users_path, class: 'log' %></h6></div>
        <% end %>
      </div>
    </div>
  </section>

  <section class="sec1 p-0 col-10">
    <header class="header">
      <% if current_user %>
        <%= link_to 'Log Out', logout_path(session), class: 'log_out_btn', method: :delete %>
      <% end %>
    </header>

    <section class="container-inner d-flex">
      <section class="tweets-container">
        <div>
          <%#= image_tag(@user.Cover_mage) %>
        </div>

        <nav class = "navbar1">
          <% if current_user %>
            <h4><%= link_to 'Tweets', tweets_path(@tweets), class: 'links' %></h4>
          <% end %>
        </nav>
          <hr class="mt-0">
        <div>
            <%= render "tweets/form", :@tweet => Tweet.new %>
        </div>

        <div class="tweet-show">
          <div>
            <div>
              <h5 class="new_tweets">8 new tweets<h5>
            </div>
            <hr>

            <div class="container-fluid ml-4 mr-4">
              <p id="notice"><%= notice %></p>
              <% @tweets.each do |tweet| %>
                <div class="author-data">
                  <% if current_user %>
                  <h4 class="author"><%= link_to current_user.username %></h4>
                  <p class="authored"><%= tweet.Text %></p>
                  <small><%= time_ago_in_words(tweet.created_at) %> ago </small>
                  <% end %>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      </section>

      <article class="articles p-0 col-4">
        <div class="articles_inner">
          <h5 class="log"><%= link_to current_user.fullName, users_path, class: 'log2' %></h5>
          <h6 class="log">@<%= link_to current_user.username, users_path, class: 'log1' %></h6>
        </div>
          <hr class="mb-0">
        <div class="stats_div d-flex">
          <% if current_user %>
            <div class="stats">
              <div class="stats2"><%= link_to current_user.tweets.count %></div>
              <p>Tweets</p>
            </div>
            <div class="stats">
              <div class="stats2"><%= link_to current_user.followers.count %></div>
              <p>followers</p>
            </div>
            <div class="stats">
            <div class="stats2"><%= link_to current_user.following.count %></div> 
              <p>following</p>
            </div>
          <% end %>
        </div>
          <hr class="mt-0">
        <div class="container-fluid pl-0 pr-0">
          
          <div>
            <h4 class="text-center pt-2">Followed by</h4>
            <hr class="mb-0">
            <div class="container-fluid">
              <% @users.each do |user| %>
                  <div>
                    <div class="container-fluid">
                    <% if current_user.id != user.id %>
                      <% if current_user.following?(user) %>
                        <h4 class="log_users"><%= link_to user.username.titleize, users_path, class: 'to_follow' %></h4>
                        <%= link_to 'unfollow', unfollow_user_user_path(user), method: :delete, class: 'unfollow' %>
                      <% else %>
                        <h4 class="log_users"><%= link_to user.username.titleize, users_path, class: 'to_follow' %></h4>
                        <%= link_to 'follow', follow_user_user_path(user), class: 'unfollow' %>
                      <% end %>
                    <% end %>
                    </div>
                  </div>
              <% end %>
            </div>
          </div>          
        </div>
      </article>
    </section>
  </section>
</section>



