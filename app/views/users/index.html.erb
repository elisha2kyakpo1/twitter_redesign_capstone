<section class="">  
  <section class="sec1 p-0">
    <header class="header position-sticky">
      <% if current_user %>
        <%= link_to 'Log Out', logout_path(session), class: 'log_out_btn', method: :delete %>
      <% end %>
    </header>

    <section class="container-inner d-flex">
      <section class="tweets-container">
        <div>
          <%#= image_tag(@user.Cover_mage) %>
        </div>

        <nav class = "navbar1">
          <% if current_user %>
            <h4><%= link_to 'Tweets', tweets_path(@tweets), class: 'links' %></h4>
          <% end %>
        </nav>
          <hr class="mt-0">
        <div>
            <%= render "tweets/form", :@tweet => Tweet.new %>
        </div>

        <div class="tweet-show">
          <div>
            <div>
              <h5 class="new_tweets">8 new tweets<h5>
            </div>
            <hr>

            <div class="container-fluid ml-4 pr-4">
              <p id="notice"><%= notice %></p>
              <% @tweets.each do |tweet| %>
                <div class="author-data">
                  <% if current_user == tweet.author %>
                  <h4 class="author"><%= link_to tweet.author.username, users_path %></h4>
                  <p class="authored"><%= tweet.text %></p>
                  <small><%= time_ago_in_words(tweet.created_at) %> ago </small>
                  <% end %>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      </section>

      <article class="articles p-0 col-4">
        <div class="articles_inner">
          <% if current_user %>
            <h4><%= current_user.full_name.titleize %></h4>
            <p>@<%= current_user.username.titleize %></p>
          <% end %>
        </div>
          <hr class="mb-0">
        <div class="stats_div d-flex">
          <% if current_user %>
            <div class="stats">
              <div class="stats2"><%= link_to current_user.tweets.count%></div>
              <p>Tweets</p>
            </div>
            <div class="stats">
              <div class="stats2"><%= link_to current_user.followers.count %></div>
              <p>followers</p>
            </div>
            <div class="stats">
            <div class="stats2"><%= link_to current_user.following.count %></div> 
              <p>following</p>
            </div>
          <% end %>
        </div>
          <hr class="mt-0">
        <div class="container-fluid pl-0 pr-0">
          
          <div>
            <h4 class="text-center pt-2">Followed by</h4>
            <hr class="mb-0">
            <div class="container-fluid">
              <% @users.each do |user| %>
                  <div>
                    <div class="container-fluid">
                    <%# if current_user.id != user.id %>
                      <% if current_user == user.following %>
                        <h4 class="log_users"><%= link_to user.username.titleize, users_path(user), class: 'to_follow' %></h4>
                      <% end %>
                    <% end %>
                    </div>
                  </div>
              <%# end %>
            </div>
          </div>          
        </div>
      </article>
    </section>
  </section>
</section>



