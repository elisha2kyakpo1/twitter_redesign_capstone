<section class="d-grid row">  
      <%#= image_tag "image.jpg" %>
  <section class="sec2 container-fluid col-2">
    <div class="logout">
      <div class="profile d-flex mt-2">
        <div>
          <% if current_user %>
            <h5 class="log"><%= link_to current_user.username, users_path, class: 'log' %></h5>
          <% end %>
        </div>
      </div>

      <div class="d-flex follow container-fluid">
        <div><p class="log_out mr-2">following</p></div>
        <div><p class="log_out">followers</p></div>
      </div>

      <div class="nav-side">
        <% if current_user %>
          <div class="log-homes"><h6 class="log"><%= link_to 'HOME', tweets_path, class: 'log' %></h6></div>
          <div class="log-homes"><h6 class="log">CONNECT</h6></div>
          <div class="log-homes"><h6 class="log">DISCOVER</h6></div>
          <div class="log-homes"><h6 class="log"><%= link_to 'PROFILE', user_path(current_user), class: 'log' %></h6></div>
        <% end %>
      </div>
    </div>
  </section>

  <section class="sec1 p-0 col-10">
    <header class="header">
      <% if current_user %>
        <%= link_to 'Log Out', logout_path, class: 'log_out_btn', method: :delete %>
      <% end %>
    </header>

    <section class="container-inner d-flex">
      <section class="tweets-container">
        <nav class = "navbar1">
          <%# if current_user %>
            <h4><%= link_to 'Tweets', tweets_path, class: 'links' %></h4>
          <%# end %>
        </nav>
          <hr class="mt-0">
        <div>
          <div>
            <%#= render partial: 'tweets/form' %>
          </div>
        </div>

        <div class="tweet-show">
          <div>
            <div>
              <h5 class="new_tweets">8 new tweets<h5>
            </div>
            <hr>

            <div>
              <p id="notice"><%= notice %></p>
              <%# tweets.each do |tweet| %>
                <div class="author-data">
                  <%# if current_user %>
                  <h4 class="author"><%#= link_to tweet.author.username %></h4>
                  <p class="authored"><%#= tweet.Text %></p>
                  <small><%#= time_ago_in_words(tweet.created_at) %> ago </small>
                  <%# end %>
                  <%#= link_to 'Show', tweet %>
                  <%#= link_to 'Edit', edit_tweet_path(tweet) %>
                  <%#= link_to 'Destroy', tweet, method: :delete, data: { confirm: 'Are you sure?' } %>
                </div>
              <%# end %>
            </div>
          </div>
        </div>
      </section>

      <article class="articles p-0 col-4">
        <div class="articles_inner">
          <h5 class="log"><%= link_to current_user.fullName, users_path, class: 'log2' %></h5>
          <h6 class="log">@<%= link_to current_user.username, users_path, class: 'log1' %></h6>
        </div>
        <div class="stats_div d-flex">
          <% if current_user %>
            <div class="stats">
              <%#= @current_user.tweets.count %>
              <p>Tweets</p>
            </div>
            <div class="stats">
              <%#= @current_user.tweets.count %>
              <p>followers</p>
            </div>
            <div class="stats"> 
              <%#= @current_user.tweets.count %>
              <p>following</p>
            </div>
          <% end %>
        </div>
          <hr class="mt-0">
        <div class="container-fluid">
          <div>
            <h4 class="text-center pt-2">Followed by</h4>
            <% if current_user %>
            <% else %>
            <% end %>
          </div>

          <%# @followers.each do |f| %>
            <p><%#= f.username %> </p>
          <%# end %>
          
        </div>
      </article>
    </section>
  </section>
</section>






<div class="container-fluid">
  <%# @users.each do |user| %>
    <%# if user.followings %>
      <h5><%#= link_to user.username %></h5>
      <%#= link_to "follow", follow_users_path(@following), class: "unfollow"  %>
    <%# else %>
      <h5><%#= link_to user.username %></h5>
      <%#= link_to "unfollow", unfollow_users_path(@followed), class: "unfollow" %>
    <%# end %>
  <%# end %>
</div>


